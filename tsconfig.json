{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true
  },
  "include": ["src", "tests"],
  "exclude": [
    "node_modules",
    "dist"
    // W3 fold-in landed: the responsive-kernel / termbar / perm-cell-cap /
    // tabs-code-kindLabel / chart-canvas-reaction suites are re-included now that
    // their implementations exist (src/kernel/responsive.ts,
    // src/components/{termbar,tabs,code,kindLabel}/**, the widened perm-cell, and
    // the chart onThemeChange reaction).
  ]
}
